{
  "compilerOptions": {
    "moduleResolution": "Bundler",
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["test"]
}
