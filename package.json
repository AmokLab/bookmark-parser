{
  "name": "@amoklab/bookmark-parser",
  "version": "0.0.2",
  "description": "Bookmark parser",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmokLab/bookmark-parser.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup --watch --sourcemap --dts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts' 'test/**/*.ts' 'tsup.config.ts'",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'src/index.ts' 'test/**/*.ts' 'tsup.config.ts'"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  },
  "keywords": [],
  "author": "leangseu",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}